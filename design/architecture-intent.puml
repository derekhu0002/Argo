@startuml
!include <archimate/Archimate>

left to right direction

title Argo Architecture Intent

' Business layer
archimate #FFF2CC "Development Team" <<business-actor>> as devTeam
archimate #FFF2CC "Chief Architecture Referee" <<business-role>> as chiefReferee
archimate #FFF2CC "Initialize Architecture Workflow" <<business-process>> as initWorkflow
archimate #FFF2CC "Baseline Extraction Workflow" <<business-process>> as baselineWorkflow
archimate #FFF2CC "Architecture Evolution Workflow" <<business-process>> as evolveWorkflow
archimate #FFF2CC "Traceability Workflow" <<business-process>> as traceWorkflow
archimate #FFF2CC "Architecture Intent" <<business-object>> as intentArtifact
archimate #FFF2CC "Traceability Matrix" <<business-object>> as traceMatrix

' Application layer
archimate #D5E8D4 "@argo Chat Interface" <<application-interface>> as chatInterface
archimate #D5E8D4 "Chat Participant Router" <<application-component>> as participantRouter
archimate #D5E8D4 "Init Orchestrator" <<application-component>> as initService
archimate #D5E8D4 "Baseline Orchestrator" <<application-component>> as baselineService
archimate #D5E8D4 "Evolution Orchestrator" <<application-component>> as evolveService
archimate #D5E8D4 "Traceability Orchestrator" <<application-component>> as linkService
archimate #D5E8D4 "Semantic UML Engine" <<application-component>> as semanticEngine
archimate #D5E8D4 "Architecture Stitch Judge" <<application-component>> as stitchJudge
archimate #D5E8D4 "Copilot Model Gateway" <<application-component>> as modelGateway
archimate #D5E8D4 "Design Asset Store" <<application-component>> as designAssetStore
archimate #D5E8D4 "Implementation UML" <<application-data-object>> as implementationUml

' Technology layer
archimate #DAE8FC "VS Code Extension Host" <<technology-node>> as vscodeHost
archimate #DAE8FC "GitHub Copilot Chat" <<technology-system-software>> as copilotChat
archimate #DAE8FC "Workspace FS API" <<technology-interface>> as workspaceFs
archimate #DAE8FC "Language Intelligence Service" <<technology-service>> as symbolService

' Business relationships
Rel_Assignment(devTeam, chiefReferee, "delegates architecture control to")
Rel_Association(devTeam, initWorkflow, "triggers")
Rel_Association(devTeam, baselineWorkflow, "triggers")
Rel_Association(devTeam, evolveWorkflow, "triggers")
Rel_Association(devTeam, traceWorkflow, "triggers")
Rel_Access(initWorkflow, intentArtifact, "reads")
Rel_Access(evolveWorkflow, intentArtifact, "reads")
Rel_Access(traceWorkflow, intentArtifact, "reads")
Rel_Access(traceWorkflow, traceMatrix, "produces")

' Application relationships
Rel_Serving(chatInterface, devTeam, "serves")
Rel_Assignment(chiefReferee, participantRouter, "realized by")
Rel_Realization(participantRouter, chatInterface, "exposes")
Rel_Composition(participantRouter, initService)
Rel_Composition(participantRouter, baselineService)
Rel_Composition(participantRouter, evolveService)
Rel_Composition(participantRouter, linkService)

Rel_Triggering(initService, semanticEngine, "extracts implementation semantics from generated code")
Rel_Triggering(initService, stitchJudge, "requests stitch validation")
Rel_Triggering(baselineService, semanticEngine, "runs full baseline extraction")
Rel_Triggering(evolveService, semanticEngine, "captures current implementation view")
Rel_Triggering(evolveService, stitchJudge, "runs anti-corruption check")
Rel_Triggering(linkService, semanticEngine, "extracts implementation view")
Rel_Triggering(linkService, stitchJudge, "builds traceability assessment")
Rel_Association(initService, modelGateway, "uses")
Rel_Association(baselineService, modelGateway, "uses")
Rel_Association(evolveService, modelGateway, "uses")
Rel_Association(linkService, modelGateway, "uses")
Rel_Association(semanticEngine, modelGateway, "uses")
Rel_Association(stitchJudge, modelGateway, "uses")
Rel_Association(initService, designAssetStore, "reads intent and writes implementation UML")
Rel_Association(baselineService, designAssetStore, "writes implementation UML")
Rel_Association(evolveService, designAssetStore, "reads intent and writes implementation UML")
Rel_Association(linkService, designAssetStore, "reads intent and implementation UML")
Rel_Access(designAssetStore, intentArtifact, "stores")
Rel_Access(designAssetStore, implementationUml, "stores")
Rel_Access(linkService, traceMatrix, "produces")

' Technology relationships
Rel_Assignment(vscodeHost, participantRouter, "hosts")
Rel_Assignment(copilotChat, modelGateway, "provides model runtime for")
Rel_Association(semanticEngine, symbolService, "uses")
Rel_Association(designAssetStore, workspaceFs, "uses")
@enduml